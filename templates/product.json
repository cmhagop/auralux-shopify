{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        },
        "collapsible-row-0": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Materials & Quality",
            "icon": "leather",
            "content": "<p>Handcrafted using 18k solid gold and ethically sourced diamonds. Every piece is inspected by our master artisans to ensure eternal brilliance.<\/p>"
          }
        },
        "collapsible-row-1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "<p>Complimentary worldwide shipping. Returns accepted within 30 days in original condition.<\/p>"
          }
        },
        "collapsible-row-2": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "The Aura Warranty",
            "icon": "heart",
            "content": "<p>A lifetime commitment to quality. We offer complimentary resizing and annual polishing for all Aura Lux pieces.<\/p>"
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "collapsible-row-0",
        "collapsible-row-1",
        "collapsible-row-2"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 60,
        "padding_bottom": 40
      }
    },
    "aura_lux_trust": {
      "type": "aura-lux-trust",
      "settings": {
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Complementary Pieces",
        "heading_size": "h2",
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 60,
        "padding_bottom": 40
      }
    }
  },
  "order": [
    "main",
    "aura_lux_trust",
    "related-products"
  ]
}

