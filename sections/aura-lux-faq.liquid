{%- style -%}
  .aura-lux-faq-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
  }

  .aura-lux-faq__header {
    text-align: center;
    margin-bottom: 8rem;
  }

  .aura-lux-faq__label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.5rem;
    font-size: 1.1rem;
    color: rgb(var(--color-accent));
    margin-bottom: 2rem;
    font-weight: 600;
  }

  .aura-lux-faq__heading {
    margin-bottom: 0;
    letter-spacing: -0.03em;
  }

  .aura-lux-faq__container {
    max-width: 75rem;
    margin: 0 auto;
  }

  .aura-lux-faq__item {
    border-bottom: 1px solid rgba(var(--color-foreground), 0.06);
  }

  .aura-lux-faq__item:first-child {
    border-top: 1px solid rgba(var(--color-foreground), 0.06);
  }

  .aura-lux-faq__question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 3rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body-family);
    font-size: 1.55rem;
    letter-spacing: 0.02em;
    color: rgb(var(--color-foreground));
    transition: opacity 0.3s ease;
    font-weight: 500;
  }

  .aura-lux-faq__question:hover {
    opacity: 0.6;
  }

  .aura-lux-faq__icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    opacity: 0.35;
    flex-shrink: 0;
    margin-left: 2rem;
  }

  .aura-lux-faq__item[open] .aura-lux-faq__icon {
    transform: rotate(180deg);
  }

  .aura-lux-faq__answer {
    padding-bottom: 3.5rem;
    font-size: 1.5rem;
    line-height: 1.9;
    opacity: 0.65;
    max-width: 60rem;
    animation: faqSlideDown 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  @keyframes faqSlideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 0.65; transform: translateY(0); }
  }
{%- endstyle -%}

<section class="aura-lux-faq-{{ section.id }}">
  <div class="page-width">
    <div class="aura-lux-faq__header">
       <span class="aura-lux-faq__label">Common Inquiries</span>
       <h2 class="aura-lux-faq__heading h1">{{ section.settings.heading | escape }}</h2>
    </div>

    <div class="aura-lux-faq__container">
      {%- for block in section.blocks -%}
        <details class="aura-lux-faq__item" {{ block.shopify_attributes }}>
          <summary class="aura-lux-faq__question">
            <span>{{ block.settings.question | escape }}</span>
            <span class="aura-lux-faq__icon">{% render 'icon-caret' %}</span>
          </summary>
          <div class="aura-lux-faq__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elegance Explained"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I determine my ring size?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a complimentary sizing kit for all orders. Alternatively, you can visit our sizing guide for detailed instructions on measuring at home.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura Lux FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item", "settings": { "question": "What is the delivery timeline?", "answer": "<p>Each piece is handcrafted to order. Standard delivery takes 2-4 weeks, ensuring the highest level of detail for your Aura Ring.</p>" } },
        { "type": "faq_item", "settings": { "question": "Are your materials ethically sourced?", "answer": "<p>Sustainability is at the core of Aura Lux. We use 100% recycled precious metals and conflict-free diamonds certified by the Kimberley Process.</p>" } }
      ]
    }
  ]
}
{% endschema %}
