{%- style -%}
  .aura-faq {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
  }

  .aura-faq__header {
    text-align: center;
    margin-bottom: 6rem;
  }

  .aura-faq__label {
    display: block;
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.4;
    margin-bottom: 1.5rem;
  }

  .aura-faq__heading {
    font-size: clamp(2.4rem, 3vw, 3.4rem);
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .aura-faq__container {
    max-width: 70rem;
    margin: 0 auto;
  }

  .aura-faq__item {
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .aura-faq__item:first-child {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .aura-faq__question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2.5rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    letter-spacing: 0;
    color: rgb(var(--color-foreground));
    transition: opacity 0.25s ease;
    font-weight: 500;
  }

  .aura-faq__question:hover {
    opacity: 0.55;
  }

  .aura-faq__icon {
    width: 1.6rem;
    height: 1.6rem;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.3;
    flex-shrink: 0;
    margin-left: 2rem;
  }

  .aura-faq__item[open] .aura-faq__icon {
    transform: rotate(45deg);
  }

  .aura-faq__answer {
    padding-bottom: 2.5rem;
    font-size: 1.45rem;
    line-height: 1.8;
    opacity: 0.55;
    max-width: 58rem;
  }
{%- endstyle -%}

<section class="aura-faq">
  <div class="page-width">
    <div class="aura-faq__header">
      <span class="aura-faq__label">FAQ</span>
      <h2 class="aura-faq__heading">{{ section.settings.heading | escape }}</h2>
    </div>

    <div class="aura-faq__container">
      {%- for block in section.blocks -%}
        <details class="aura-faq__item" {{ block.shopify_attributes }}>
          <summary class="aura-faq__question">
            <span>{{ block.settings.question | escape }}</span>
            <span class="aura-faq__icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </summary>
          <div class="aura-faq__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Common questions"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I determine my ring size?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a complimentary sizing kit with every order. You can also visit our sizing guide for detailed instructions on measuring at home.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura Lux FAQ",
      "blocks": [
        { "type": "faq_item" },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is the delivery timeline?",
            "answer": "<p>Each piece is crafted to order. Standard delivery takes 2–4 weeks to ensure the highest quality.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are your materials ethically sourced?",
            "answer": "<p>Yes. We use 100% recycled precious metals and conflict-free materials certified by the Kimberley Process.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
