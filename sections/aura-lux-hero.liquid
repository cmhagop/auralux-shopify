{%- style -%}
  .aura-hero {
    position: relative;
    width: 100%;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #e8e4de;
  }

  /* ── Full-bleed Image ── */
  .aura-hero__image-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .aura-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% 50%;
    display: block;
  }

  /* ── Soft readability layer ── */
  .aura-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to right,
      rgba(245, 243, 239, 0.88) 0%,
      rgba(245, 243, 239, 0.55) 45%,
      rgba(245, 243, 239, 0.1) 70%,
      transparent 100%
    );
  }

  /* ── Text Content ── */
  .aura-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 140rem;
    margin: 0 auto;
    padding: 0 5rem;
    display: flex;
    align-items: center;
    min-height: 90vh;
  }

  .aura-hero__text {
    max-width: 50rem;
  }

  .aura-hero__label {
    display: inline-block;
    font-size: 1.15rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    color: #1a1a1a;
    opacity: 0.45;
    margin-bottom: 2rem;
  }

  .aura-hero__heading {
    font-size: clamp(3rem, 4.5vw, 5rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0 0 2rem;
    font-weight: 400;
    color: #1a1a1a;
  }

  .aura-hero__description {
    font-size: 1.55rem;
    line-height: 1.75;
    color: #1a1a1a;
    opacity: 0.55;
    max-width: 40rem;
    margin: 0 0 3.5rem;
  }

  .aura-hero__actions {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  /* ── Placeholder gradient when no image ── */
  .aura-hero--no-image {
    background: linear-gradient(135deg, #f0ede8 0%, #e2ddd6 40%, #d5cfc7 100%);
  }

  /* ── Desktop ── */
  @media screen and (min-width: 990px) {
    .aura-hero {
      min-height: 92vh;
    }
    .aura-hero__content {
      min-height: 92vh;
      padding: 0 8rem;
    }
  }

  /* ── Tablet ── */
  @media screen and (max-width: 989px) and (min-width: 750px) {
    .aura-hero__overlay {
      background: linear-gradient(
        to bottom,
        rgba(245, 243, 239, 0.85) 0%,
        rgba(245, 243, 239, 0.6) 50%,
        rgba(245, 243, 239, 0.2) 100%
      );
    }
    .aura-hero__content {
      align-items: flex-start;
      padding-top: 14rem;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .aura-hero {
      min-height: 85vh;
    }
    .aura-hero__content {
      min-height: 85vh;
      padding: 0 2.4rem;
      align-items: flex-end;
      padding-bottom: 6rem;
    }
    .aura-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(245, 243, 239, 0.92) 0%,
        rgba(245, 243, 239, 0.65) 40%,
        rgba(245, 243, 239, 0.15) 70%,
        transparent 100%
      );
    }
    .aura-hero__heading {
      font-size: clamp(2.6rem, 8vw, 3.4rem);
    }
    .aura-hero__description {
      font-size: 1.4rem;
    }
    .aura-hero__image {
      object-position: 55% 40%;
    }
  }
{%- endstyle -%}

<section class="aura-hero{% unless section.settings.image %} aura-hero--no-image{% endunless %}">
  {%- if section.settings.image != blank -%}
    <div class="aura-hero__image-layer">
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          loading: 'eager',
          class: 'aura-hero__image',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: 'high'
      }}
    </div>
  {%- endif -%}

  <div class="aura-hero__overlay"></div>

  <div class="aura-hero__content">
    <div class="aura-hero__text">
      {%- if section.settings.label != blank -%}
        <span class="aura-hero__label">{{ section.settings.label | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="aura-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="aura-hero__description">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="aura-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "Aura Lux"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to be felt, not seen"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>The Aura Ring blends precision engineering with quiet elegance — crafted for those who value substance over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
