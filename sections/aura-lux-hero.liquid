{%- style -%}
  .aura-hero {
    background-color: #f9f9f7;
    overflow: hidden;
  }

  .aura-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 80vh;
  }

  /* ── Text Column ── */
  .aura-hero__text-col {
    display: flex;
    align-items: center;
    padding: 6rem 2.5rem;
  }

  .aura-hero__text {
    max-width: 48rem;
  }

  .aura-hero__label {
    display: inline-block;
    font-size: 1.15rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    color: #1a1a1a;
    opacity: 0.4;
    margin-bottom: 2rem;
  }

  .aura-hero__heading {
    font-size: clamp(2.8rem, 4vw, 4.4rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0 0 1.8rem;
    font-weight: 400;
    color: #1a1a1a;
  }

  .aura-hero__description {
    font-size: 1.5rem;
    line-height: 1.75;
    color: #1a1a1a;
    opacity: 0.5;
    max-width: 38rem;
    margin: 0 0 3rem;
  }

  .aura-hero__actions {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  /* ── Image Column ── */
  .aura-hero__image-col {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: #f0ece6;
  }

  .aura-hero__image {
    width: 100%;
    max-width: 72rem;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  /* Placeholder */
  .aura-hero__placeholder {
    width: 100%;
    max-width: 72rem;
    aspect-ratio: 1/1;
    background: linear-gradient(135deg, #e8e4de 0%, #ddd8d0 50%, #e8e4de 100%);
    border-radius: 8px;
  }

  /* ── Desktop: side by side ── */
  @media screen and (min-width: 990px) {
    .aura-hero__grid {
      grid-template-columns: 5fr 6fr;
      min-height: 88vh;
    }

    .aura-hero__text-col {
      padding: 6rem 4rem 6rem 8rem;
    }

    .aura-hero__image-col {
      padding: 3rem;
    }

    .aura-hero__image {
      max-width: none;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border-radius: 10px;
    }
  }

  /* ── Tablet ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .aura-hero__grid {
      grid-template-columns: 1fr 1fr;
      min-height: 70vh;
    }
    .aura-hero__text-col {
      padding: 4rem 3rem;
    }
    .aura-hero__image-col {
      padding: 2rem;
    }
    .aura-hero__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border-radius: 8px;
    }
  }

  /* ── Mobile: stacked, image on top ── */
  @media screen and (max-width: 749px) {
    .aura-hero__grid {
      min-height: auto;
    }
    .aura-hero__image-col {
      order: -1;
      padding: 1.5rem 1.5rem 0;
      background-color: transparent;
    }
    .aura-hero__image {
      border-radius: 10px;
    }
    .aura-hero__text-col {
      padding: 3rem 2.4rem 5rem;
      text-align: center;
    }
    .aura-hero__text {
      margin: 0 auto;
    }
    .aura-hero__actions {
      justify-content: center;
    }
    .aura-hero__heading {
      font-size: clamp(2.4rem, 7vw, 3rem);
    }
    .aura-hero__description {
      font-size: 1.4rem;
    }
  }
{%- endstyle -%}

<section class="aura-hero">
  <div class="aura-hero__grid">
    <div class="aura-hero__text-col">
      <div class="aura-hero__text">
        {%- if section.settings.label != blank -%}
          <span class="aura-hero__label">{{ section.settings.label | escape }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="aura-hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="aura-hero__description">{{ section.settings.text }}</div>
        {%- endif -%}

        <div class="aura-hero__actions">
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link }}" class="button button--primary">
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
              {{ section.settings.button_label_2 | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="aura-hero__image-col">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 2000
          | image_tag:
            loading: 'eager',
            class: 'aura-hero__image',
            widths: '375, 550, 750, 1100, 1500, 2000',
            fetchpriority: 'high'
        }}
      {%- else -%}
        <div class="aura-hero__placeholder"></div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "Aura Lux"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to be felt, not seen"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>The Aura Ring blends precision engineering with quiet elegance — crafted for those who value substance over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
