{%- style -%}
  .aura-lux-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #000;
  }

  .aura-lux-hero__content {
    position: relative;
    z-index: 10;
    max-width: 100rem;
    text-align: center;
    padding: 0 2rem;
    animation: fadeInHero 2s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .aura-lux-hero__label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.5rem;
    font-size: 1.1rem;
    margin-bottom: 3rem;
    color: #FFFFFF;
    font-weight: 600;
    opacity: 0.8;
  }

  .aura-lux-hero__heading {
    font-size: calc(var(--font-heading-scale) * 4.5rem);
    line-height: 1.05;
    margin-bottom: 3rem;
    color: #FFFFFF;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  .aura-lux-hero__text {
    font-size: 1.8rem;
    line-height: 1.8;
    margin-bottom: 5rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 65rem;
    margin-left: auto;
    margin-right: auto;
  }

  .aura-lux-hero__actions {
    display: flex;
    gap: 3rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .aura-lux-hero__actions .button--primary {
    background-color: #FFFFFF;
    color: #1A1A1A;
    border-color: #FFFFFF;
  }

  .aura-lux-hero__actions .button--primary::after {
    background-color: #1A1A1A;
  }

  .aura-lux-hero__actions .button--primary:hover {
    color: #FFFFFF;
  }

  .aura-lux-hero__actions .button--secondary {
    background-color: transparent;
    border-color: rgba(255, 255, 255, 0.5);
    color: #FFFFFF;
  }

  .aura-lux-hero__actions .button--secondary::after {
    background-color: #FFFFFF;
  }

  .aura-lux-hero__actions .button--secondary:hover {
    color: #1A1A1A;
  }

  .aura-lux-hero__image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .aura-lux-hero__image-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.6) 100%);
    z-index: 2;
  }

  .aura-lux-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.05);
    filter: brightness(0.85);
  }

  @keyframes fadeInHero {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media screen and (min-width: 990px) {
    .aura-lux-hero__heading {
      font-size: calc(var(--font-heading-scale) * 8.5rem);
    }
    .aura-lux-hero__text {
      font-size: 2.2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .aura-lux-hero-{{ section.id }} {
      min-height: 85vh;
    }
    .aura-lux-hero__heading {
      font-size: calc(var(--font-heading-scale) * 3.8rem);
    }
  }
{%- endstyle -%}

<section class="aura-lux-hero-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.image != blank -%}
    <div class="aura-lux-hero__image-container">
      {{ section.settings.image | image_url: width: 3840 | image_tag: 
        loading: 'eager',
        class: 'aura-lux-hero__image',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      }}
    </div>
  {%- endif -%}

  <div class="aura-lux-hero__content page-width">
    {%- if section.settings.label != blank -%}
      <span class="aura-lux-hero__label">{{ section.settings.label | escape }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="aura-lux-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="aura-lux-hero__text">{{ section.settings.text }}</div>
    {%- endif -%}

    <div class="aura-lux-hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button button--primary button--large">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="button button--secondary button--large">
          {{ section.settings.button_label_2 | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "The Pinnacle of Craftsmanship"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Silent Luxury for the Modern Soul"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Experience the embrace of timeless elegance with the Aura Ring—a masterpiece designed for those who value sophistication over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
