{%- style -%}
  .aura-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #ede9e3;
  }

  /* ── Image: full, uncropped, natural proportions ── */
  .aura-hero__image-layer {
    position: relative;
    width: 100%;
    z-index: 1;
  }

  .aura-hero__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    object-position: center;
  }

  /* ── Overlay: soft gradient at the bottom-left for text readability ── */
  .aura-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      to top right,
      rgba(237, 233, 227, 0.92) 0%,
      rgba(237, 233, 227, 0.7) 25%,
      rgba(237, 233, 227, 0.2) 50%,
      transparent 65%
    );
  }

  /* ── Text: positioned over the image at bottom-left ── */
  .aura-hero__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    padding: 6rem 5rem;
    max-width: 140rem;
  }

  .aura-hero__text {
    max-width: 46rem;
  }

  .aura-hero__label {
    display: inline-block;
    font-size: 1.15rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    color: #1a1a1a;
    opacity: 0.45;
    margin-bottom: 1.6rem;
  }

  .aura-hero__heading {
    font-size: clamp(2.8rem, 4vw, 4.6rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0 0 1.6rem;
    font-weight: 400;
    color: #1a1a1a;
  }

  .aura-hero__description {
    font-size: 1.5rem;
    line-height: 1.75;
    color: #1a1a1a;
    opacity: 0.5;
    max-width: 38rem;
    margin: 0 0 3rem;
  }

  .aura-hero__actions {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  /* ── Placeholder when no image assigned ── */
  .aura-hero--no-image .aura-hero__placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: linear-gradient(135deg, #f0ede8 0%, #e2ddd6 40%, #d5cfc7 100%);
  }

  .aura-hero--no-image .aura-hero__overlay {
    display: none;
  }

  .aura-hero--no-image .aura-hero__content {
    position: relative;
    padding: 14rem 5rem 8rem;
  }

  /* ── Desktop ── */
  @media screen and (min-width: 990px) {
    .aura-hero__content {
      padding: 8rem;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .aura-hero__content {
      padding: 4rem 2.4rem;
    }
    .aura-hero__heading {
      font-size: clamp(2.4rem, 7vw, 3.2rem);
    }
    .aura-hero__description {
      font-size: 1.4rem;
    }
    .aura-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(237, 233, 227, 0.95) 0%,
        rgba(237, 233, 227, 0.75) 30%,
        rgba(237, 233, 227, 0.2) 55%,
        transparent 70%
      );
    }
  }
{%- endstyle -%}

<section class="aura-hero{% unless section.settings.image %} aura-hero--no-image{% endunless %}">
  {%- if section.settings.image != blank -%}
    <div class="aura-hero__image-layer">
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          loading: 'eager',
          class: 'aura-hero__image',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: 'high'
      }}
      <div class="aura-hero__overlay"></div>
    </div>
  {%- else -%}
    <div class="aura-hero__image-layer">
      <div class="aura-hero__placeholder"></div>
    </div>
  {%- endif -%}

  <div class="aura-hero__content">
    <div class="aura-hero__text">
      {%- if section.settings.label != blank -%}
        <span class="aura-hero__label">{{ section.settings.label | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="aura-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="aura-hero__description">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="aura-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "Aura Lux"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to be felt, not seen"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>The Aura Ring blends precision engineering with quiet elegance — crafted for those who value substance over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
