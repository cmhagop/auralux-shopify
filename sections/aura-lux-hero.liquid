{%- style -%}
  /* ── Smooth Hero ── */
  .aura-hero {
    background-color: #f9f9f7;
    color: #1a1a1a;
    position: relative;
    overflow: hidden;
  }

  .aura-hero__inner {
    max-width: 140rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .aura-hero__text-block {
    text-align: center;
    padding: 14rem 2rem 5rem;
    max-width: 80rem;
    margin: 0 auto;
  }

  .aura-hero__label {
    display: inline-block;
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.45;
    margin-bottom: 2rem;
  }

  .aura-hero__heading {
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0 0 2rem;
    font-weight: 400;
  }

  .aura-hero__text {
    font-size: 1.6rem;
    line-height: 1.7;
    opacity: 0.55;
    max-width: 48rem;
    margin: 0 auto 3.5rem;
  }

  .aura-hero__actions {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 6rem;
  }

  /* ── Hero Image ── */
  .aura-hero__image-block {
    padding: 0 2rem 0;
  }

  .aura-hero__image-frame {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    max-width: 130rem;
    margin: 0 auto;
  }

  .aura-hero__image {
    width: 100%;
    display: block;
    aspect-ratio: 2.2 / 1;
    object-fit: cover;
    object-position: center;
    transition: transform 6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .aura-hero:hover .aura-hero__image {
    transform: scale(1.02);
  }

  /* Placeholder when no image */
  .aura-hero__placeholder {
    aspect-ratio: 2.2 / 1;
    border-radius: 16px;
    background: linear-gradient(135deg, #e8e6e1 0%, #d5d2cc 50%, #e8e6e1 100%);
    max-width: 130rem;
    margin: 0 auto;
  }

  /* ── Responsive ── */
  @media screen and (min-width: 990px) {
    .aura-hero__text-block {
      padding: 16rem 4rem 6rem;
    }
    .aura-hero__image-block {
      padding: 0 4rem 0;
    }
  }

  @media screen and (max-width: 749px) {
    .aura-hero__text-block {
      padding: 10rem 1.5rem 3.5rem;
    }
    .aura-hero__heading {
      font-size: clamp(2.6rem, 7vw, 3.6rem);
    }
    .aura-hero__text {
      font-size: 1.45rem;
    }
    .aura-hero__image-frame {
      border-radius: 12px;
    }
    .aura-hero__image {
      aspect-ratio: 16 / 10;
    }
    .aura-hero__image-block {
      padding: 0 1.2rem 0;
    }
    .aura-hero__actions {
      margin-bottom: 4rem;
    }
  }
{%- endstyle -%}

<section class="aura-hero">
  <div class="aura-hero__inner">
    <div class="aura-hero__text-block">
      {%- if section.settings.label != blank -%}
        <span class="aura-hero__label">{{ section.settings.label | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="aura-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="aura-hero__text">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="aura-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.image != blank -%}
      <div class="aura-hero__image-block">
        <div class="aura-hero__image-frame">
          {{
            section.settings.image
            | image_url: width: 3840
            | image_tag:
              loading: 'eager',
              class: 'aura-hero__image',
              widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
          }}
        </div>
      </div>
    {%- else -%}
      <div class="aura-hero__image-block">
        <div class="aura-hero__placeholder"></div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "Aura Lux"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to be felt, not seen"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>The Aura Ring blends precision engineering with quiet elegance — crafted for those who value substance over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
