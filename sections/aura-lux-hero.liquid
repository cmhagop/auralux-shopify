{%- style -%}
  .aura-hero {
    background-color: #0D0D0D;
    color: #F5F5F0;
    overflow: hidden;
  }

  /* ── Text Block ── */
  .aura-hero__text-block {
    padding: 12rem 2rem 6rem;
    text-align: center;
    position: relative;
    z-index: 5;
  }

  .aura-hero__label {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.6rem;
    font-size: 1rem;
    margin-bottom: 3rem;
    color: #C5A059;
    font-weight: 600;
    opacity: 0.9;
    animation: heroFadeUp 1.2s cubic-bezier(0.19, 1, 0.22, 1) 0.2s both;
  }

  .aura-hero__heading {
    font-size: calc(var(--font-heading-scale) * 4.5rem);
    line-height: 1.05;
    margin: 0 auto 3rem;
    color: #F5F5F0;
    font-weight: 400;
    letter-spacing: -0.04em;
    max-width: 90rem;
    animation: heroFadeUp 1.2s cubic-bezier(0.19, 1, 0.22, 1) 0.4s both;
  }

  .aura-hero__text {
    font-size: 1.7rem;
    line-height: 1.85;
    margin: 0 auto 4.5rem;
    color: rgba(245, 245, 240, 0.65);
    max-width: 55rem;
    animation: heroFadeUp 1.2s cubic-bezier(0.19, 1, 0.22, 1) 0.6s both;
  }

  .aura-hero__actions {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: heroFadeUp 1.2s cubic-bezier(0.19, 1, 0.22, 1) 0.8s both;
  }

  .aura-hero__actions .button--primary {
    background-color: #C5A059;
    color: #0D0D0D;
    border-color: #C5A059;
    letter-spacing: 0.2rem;
  }

  .aura-hero__actions .button--primary::after {
    background-color: #F5F5F0;
  }

  .aura-hero__actions .button--primary:hover {
    color: #0D0D0D;
  }

  .aura-hero__actions .button--secondary {
    background-color: transparent;
    border-color: rgba(245, 245, 240, 0.25);
    color: #F5F5F0;
  }

  .aura-hero__actions .button--secondary::after {
    background-color: #F5F5F0;
  }

  .aura-hero__actions .button--secondary:hover {
    color: #0D0D0D;
  }

  /* ── Image Block ── */
  .aura-hero__image-block {
    position: relative;
    width: 100%;
    max-width: 130rem;
    margin: 0 auto;
    padding: 0 3rem 6rem;
    animation: heroFadeUp 1.5s cubic-bezier(0.19, 1, 0.22, 1) 1s both;
  }

  .aura-hero__image-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(197, 160, 89, 0.12);
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.5),
      0 0 80px rgba(197, 160, 89, 0.04);
  }

  .aura-hero__image-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(13, 13, 13, 0.15) 0%,
      transparent 30%,
      transparent 70%,
      rgba(13, 13, 13, 0.4) 100%
    );
    z-index: 2;
    pointer-events: none;
  }

  .aura-hero__image {
    width: 100%;
    display: block;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    object-position: center;
    transition: transform 8s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .aura-hero:hover .aura-hero__image {
    transform: scale(1.03);
  }

  /* ── Decorative ── */
  .aura-hero__glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 40%;
    background: radial-gradient(ellipse, rgba(197, 160, 89, 0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Animation ── */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ── */
  @media screen and (min-width: 990px) {
    .aura-hero__text-block {
      padding: 16rem 4rem 8rem;
    }
    .aura-hero__heading {
      font-size: calc(var(--font-heading-scale) * 8rem);
    }
    .aura-hero__text {
      font-size: 2rem;
    }
    .aura-hero__image {
      aspect-ratio: 21 / 9;
    }
    .aura-hero__image-block {
      padding: 0 6rem 8rem;
    }
  }

  @media screen and (max-width: 749px) {
    .aura-hero__text-block {
      padding: 10rem 2rem 4rem;
    }
    .aura-hero__heading {
      font-size: calc(var(--font-heading-scale) * 3.4rem);
    }
    .aura-hero__image {
      aspect-ratio: 16 / 10;
    }
    .aura-hero__image-block {
      padding: 0 1.5rem 4rem;
    }
  }
{%- endstyle -%}

<section class="aura-hero">
  <div class="aura-hero__glow"></div>

  <div class="aura-hero__text-block">
    {%- if section.settings.label != blank -%}
      <span class="aura-hero__label">{{ section.settings.label | escape }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="aura-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="aura-hero__text">{{ section.settings.text }}</div>
    {%- endif -%}

    <div class="aura-hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button button--primary">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
          {{ section.settings.button_label_2 | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.image != blank -%}
    <div class="aura-hero__image-block">
      <div class="aura-hero__image-frame">
        {{ section.settings.image | image_url: width: 3840 | image_tag:
          loading: 'eager',
          class: 'aura-hero__image',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
      </div>
    </div>
  {%- else -%}
    <div class="aura-hero__image-block">
      <div class="aura-hero__image-frame" style="aspect-ratio: 21/9; background: linear-gradient(135deg, #1a1710 0%, #2c2418 50%, #1a1710 100%);"></div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "The Pinnacle of Craftsmanship"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Silent Luxury for the Modern Soul"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Experience the embrace of timeless elegance with the Aura Ring—a masterpiece designed for those who value sophistication over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
