{%- style -%}
  .aura-hero {
    position: relative;
    width: 100%;
    min-height: 85vh;
    overflow: hidden;
    background-color: #efebe5;
    display: flex;
    align-items: center;
  }

  /* ── Full-bleed Image Layer ── */
  .aura-hero__image-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .aura-hero__image-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    display: block;
  }

  /* ── Subtle left-side gradient for text readability ── */
  .aura-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      rgba(249, 249, 247, 0.82) 0%,
      rgba(249, 249, 247, 0.6) 30%,
      rgba(249, 249, 247, 0.15) 55%,
      transparent 70%
    );
  }

  /* ── Text Content ── */
  .aura-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 140rem;
    margin: 0 auto;
    padding: 0 5rem;
  }

  .aura-hero__text {
    max-width: 44rem;
  }

  .aura-hero__label {
    display: inline-block;
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    color: #1a1a1a;
    opacity: 0.4;
    margin-bottom: 2rem;
  }

  .aura-hero__heading {
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin: 0 0 1.6rem;
    font-weight: 400;
    color: #1a1a1a;
  }

  .aura-hero__description {
    font-size: 1.5rem;
    line-height: 1.75;
    color: #1a1a1a;
    opacity: 0.5;
    max-width: 36rem;
    margin: 0 0 2.8rem;
  }

  .aura-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .aura-hero__actions .button {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 100px;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    padding: 1.1rem 2.6rem;
    min-height: 4.4rem;
    font-weight: 500;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    text-transform: none;
    background: rgba(120, 115, 108, 0.18);
    color: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .aura-hero__actions .button:hover {
    background: rgba(120, 115, 108, 0.3);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .aura-hero__actions .button--primary {
    background: rgba(100, 96, 90, 0.25);
    color: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .aura-hero__actions .button--primary:hover {
    background: rgba(100, 96, 90, 0.38);
  }

  .aura-hero__actions .button--secondary {
    background: rgba(140, 135, 128, 0.14);
    color: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .aura-hero__actions .button--secondary:hover {
    background: rgba(140, 135, 128, 0.25);
  }

  /* ── Placeholder state ── */
  .aura-hero__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #e8e4dc 0%, #d8d2c8 40%, #e2ddd5 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aura-hero__placeholder-text {
    opacity: 0.2;
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }

  /* ── Desktop ── */
  @media screen and (min-width: 990px) {
    .aura-hero {
      min-height: 90vh;
    }
    .aura-hero__content {
      padding: 0 8rem;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .aura-hero {
      min-height: 75vh;
      align-items: flex-end;
    }
    .aura-hero__content {
      padding: 0 2.4rem 5rem;
    }
    .aura-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(249, 249, 247, 0.9) 0%,
        rgba(249, 249, 247, 0.65) 35%,
        rgba(249, 249, 247, 0.1) 60%,
        transparent 75%
      );
    }
    .aura-hero__heading {
      font-size: clamp(2.4rem, 7vw, 3rem);
    }
    .aura-hero__description {
      font-size: 1.4rem;
    }
    .aura-hero__image-layer img {
      object-position: 55% center;
    }
  }
{%- endstyle -%}

<section class="aura-hero">
  {%- if section.settings.image != blank -%}
    <div class="aura-hero__image-layer">
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          loading: 'eager',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: 'high'
      }}
    </div>
    <div class="aura-hero__overlay"></div>
  {%- else -%}
    <div class="aura-hero__placeholder">
      <span class="aura-hero__placeholder-text">Select hero image in Customize</span>
    </div>
  {%- endif -%}

  <div class="aura-hero__content">
    <div class="aura-hero__text">
      {%- if section.settings.label != blank -%}
        <span class="aura-hero__label">{{ section.settings.label | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="aura-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="aura-hero__description">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="aura-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "Aura Lux"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to be felt, not seen"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>The Aura Ring blends precision engineering with quiet elegance — crafted for those who value substance over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
