{%- style -%}
  .aura-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    background-color: #d5cfc5;
    display: flex;
    align-items: flex-end;
  }

  /* ── Full-bleed product image ── */
  .aura-hero__image-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .aura-hero__image-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    display: block;
  }

  /* ── Content ── */
  .aura-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 140rem;
    margin: 0 auto;
    padding: 0 5rem 8rem;
  }

  .aura-hero__text {
    max-width: 50rem;
  }

  .aura-hero__label {
    display: inline-block;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0;
    color: #1a1a1a;
    opacity: 0.65;
    margin-bottom: 1.2rem;
  }

  .aura-hero__heading {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: clamp(3.6rem, 5.5vw, 6rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0 0 3.5rem;
    font-weight: 300;
    color: rgba(26, 26, 26, 0.4);
  }

  .aura-hero__heading em,
  .aura-hero__heading i {
    color: #1a1a1a;
    font-style: normal;
  }

  .aura-hero__description {
    display: none;
  }

  .aura-hero__actions {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  .aura-hero__actions .button,
  .aura-hero__actions .button--primary,
  .aura-hero__actions .button--secondary {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
    font-size: 1.3rem !important;
    font-weight: 500 !important;
    letter-spacing: 0 !important;
    padding: 1.3rem 3rem !important;
    border-radius: 999px !important;
    min-height: 4.8rem !important;
    transition: all 0.25s ease !important;
    text-transform: none !important;
    cursor: pointer !important;
    border: none !important;
    border-width: 0 !important;
    border-style: none !important;
    border-color: transparent !important;
    outline: none !important;
    box-shadow: none !important;
  }

  .aura-hero__actions .button--primary {
    background: #ffffff !important;
    color: #111111 !important;
    border: none !important;
    outline: none !important;
  }

  .aura-hero__actions .button--primary:hover {
    background: #f0f0f0 !important;
    border: none !important;
    outline: none !important;
  }

  .aura-hero__actions .button--secondary {
    background: rgba(180, 180, 180, 0.35) !important;
    color: #111111 !important;
    border: none !important;
    outline: none !important;
    backdrop-filter: blur(8px) !important;
    -webkit-backdrop-filter: blur(8px) !important;
  }

  .aura-hero__actions .button--secondary:hover {
    background: rgba(180, 180, 180, 0.5) !important;
    border: none !important;
    outline: none !important;
  }

  /* Placeholder */
  .aura-hero__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #d5cfc5 0%, #c8c1b6 40%, #d0c9be 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aura-hero__placeholder-text {
    opacity: 0.2;
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }

  /* ── Desktop ── */
  @media screen and (min-width: 990px) {
    .aura-hero__content {
      padding: 0 8rem 10rem;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .aura-hero {
      min-height: 85vh;
    }
    .aura-hero__content {
      padding: 0 2.4rem 5rem;
    }
    .aura-hero__heading {
      font-size: clamp(3rem, 9vw, 4.2rem);
    }
    .aura-hero__image-layer img {
      object-position: 55% center;
    }
  }
{%- endstyle -%}

<section class="aura-hero">
  {%- if section.settings.image != blank -%}
    <div class="aura-hero__image-layer">
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          loading: 'eager',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: 'high'
      }}
    </div>
  {%- else -%}
    <div class="aura-hero__placeholder">
      <span class="aura-hero__placeholder-text">Select hero image in Customize</span>
    </div>
  {%- endif -%}

  <div class="aura-hero__content">
    <div class="aura-hero__text">
      {%- if section.settings.label != blank -%}
        <span class="aura-hero__label">{{ section.settings.label | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="aura-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      <div class="aura-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "Aura Ring"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Elegante, inteligente <em>y hecho para ti</em>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Descubre el Aura Ring"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label",
      "default": ""
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
