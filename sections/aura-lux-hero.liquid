{%- style -%}
  .aura-lux-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: rgb(var(--color-background));
    padding: 6rem 2rem;
  }

  .aura-lux-hero__content {
    position: relative;
    z-index: 2;
    max-width: 80rem;
    text-align: center;
    animation: fadeInHero 1.5s ease-out;
  }

  .aura-lux-hero__label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.3rem;
    font-size: 1.2rem;
    margin-bottom: 2rem;
    color: rgb(var(--color-accent));
    font-weight: 500;
  }

  .aura-lux-hero__heading {
    font-size: calc(var(--font-heading-scale) * 4rem);
    line-height: 1.1;
    margin-bottom: 2.5rem;
    letter-spacing: -0.05rem;
  }

  .aura-lux-hero__text {
    font-size: 1.8rem;
    line-height: 1.6;
    margin-bottom: 4rem;
    opacity: 0.8;
    max-width: 60rem;
    margin-left: auto;
    margin-right: auto;
  }

  .aura-lux-hero__actions {
    display: flex;
    gap: 2rem;
    justify-content: center;
  }

  .aura-lux-hero__image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .aura-lux-hero__image-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(var(--color-background), 0.2), rgba(var(--color-background), 0.6));
    z-index: 2;
  }

  .aura-lux-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.9;
  }

  @keyframes fadeInHero {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media screen and (min-width: 990px) {
    .aura-lux-hero__heading {
      font-size: calc(var(--font-heading-scale) * 7.5rem);
    }
    .aura-lux-hero-{{ section.id }} {
      min-height: 90vh;
    }
  }
{%- endstyle -%}

<section class="aura-lux-hero-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.image != blank -%}
    <div class="aura-lux-hero__image-container">
      {{ section.settings.image | image_url: width: 3840 | image_tag: 
        loading: 'eager',
        class: 'aura-lux-hero__image',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      }}
    </div>
  {%- endif -%}

  <div class="aura-lux-hero__content page-width">
    {%- if section.settings.label != blank -%}
      <span class="aura-lux-hero__label">{{ section.settings.label | escape }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="aura-lux-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="aura-lux-hero__text">{{ section.settings.text }}</div>
    {%- endif -%}

    <div class="aura-lux-hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button button--primary button--large">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="button button--secondary button--large">
          {{ section.settings.button_label_2 | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sub-label",
      "default": "The Pinnacle of Craftsmanship"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Silent Luxury for the Modern Soul"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Experience the embrace of timeless elegance with the Aura Ring—a masterpiece designed for those who value sophistication over noise.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Hero"
    }
  ]
}
{% endschema %}
