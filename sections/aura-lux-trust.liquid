{%- style -%}
  .aura-lux-trust-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
  }

  .aura-lux-trust__inner {
    max-width: 110rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .aura-lux-trust__item {
    padding: 5rem 4rem;
    text-align: center;
    position: relative;
  }

  .aura-lux-trust__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 25%;
    height: 50%;
    width: 1px;
    background: rgba(var(--color-foreground), 0.08);
  }

  .aura-lux-trust__icon {
    width: 2.4rem;
    height: 2.4rem;
    margin: 0 auto 2.5rem;
    color: rgb(var(--color-accent));
    opacity: 0.8;
  }

  .aura-lux-trust__heading {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    letter-spacing: 0.35rem;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
  }

  .aura-lux-trust__text {
    font-size: 1.35rem;
    opacity: 0.55;
    line-height: 1.7;
    max-width: 28rem;
    margin: 0 auto;
  }

  @media screen and (max-width: 749px) {
    .aura-lux-trust__inner {
      grid-template-columns: 1fr;
    }
    .aura-lux-trust__item:not(:last-child)::after {
      right: 15%;
      top: auto;
      bottom: 0;
      height: 1px;
      width: 70%;
      background: rgba(var(--color-foreground), 0.06);
    }
    .aura-lux-trust__item {
      padding: 3.5rem 2rem;
    }
  }
{%- endstyle -%}

<section class="aura-lux-trust-{{ section.id }}">
  <div class="page-width">
    <div class="aura-lux-trust__inner">
      {%- for block in section.blocks -%}
        <div class="aura-lux-trust__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_svg != blank -%}
             <div class="aura-lux-trust__icon">{{ block.settings.icon_svg }}</div>
          {%- else -%}
             <div class="aura-lux-trust__icon">
                {% render 'icon-checkmark' %}
             </div>
          {%- endif -%}

          <h3 class="aura-lux-trust__heading">{{ block.settings.title | escape }}</h3>
          <p class="aura-lux-trust__text">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Trust Bar",
  "max_blocks": 4,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Complimentary worldwide delivery on all orders."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "title": "Ethical Sourcing",
            "text": "Every diamond is conflict-free and responsibly sourced."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Lifetime Warranty",
            "text": "Our commitment to quality lasts a lifetime."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Bespoke Design",
            "text": "Individually handcrafted for your specific journey."
          }
        }
      ]
    }
  ]
}
{% endschema %}
