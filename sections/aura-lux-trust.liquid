{%- style -%}
  .aura-lux-trust-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #f2f2f0; /* Warm subtle grey */
    border-top: 1px solid rgba(var(--color-foreground), 0.05);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.05);
  }

  .aura-lux-trust__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    gap: 4rem;
    text-align: center;
  }

  .aura-lux-trust__item {
    flex: 1 1 20rem;
    max-width: 30rem;
    padding: 2rem;
  }

  .aura-lux-trust__icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 2rem;
    color: rgb(var(--color-accent));
  }

  .aura-lux-trust__heading {
    font-size: 1.4rem;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .aura-lux-trust__text {
    font-size: 1.4rem;
    opacity: 0.7;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .aura-lux-trust__grid {
      flex-direction: column;
      align-items: center;
      gap: 3rem;
    }
  }
{%- endstyle -%}

<section class="aura-lux-trust-{{ section.id }}">
  <div class="page-width">
    <div class="aura-lux-trust__grid">
      
      {%- for block in section.blocks -%}
        <div class="aura-lux-trust__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_svg != blank -%}
             <div class="aura-lux-trust__icon">{{ block.settings.icon_svg }}</div>
          {%- else -%}
             <div class="aura-lux-trust__icon">
                {% render 'icon-checkmark' %}
             </div>
          {%- endif -%}

          <h3 class="aura-lux-trust__heading">{{ block.settings.title | escape }}</h3>
          <p class="aura-lux-trust__text">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Trust Bar",
  "max_blocks": 4,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Complimentary worldwide delivery on all orders."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "title": "Ethical Sourcing",
            "text": "Every diamond is conflict-free and responsibly sourced."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Lifetime Warranty",
            "text": "Our commitment to quality lasts a lifetime."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Bespoke Design",
            "text": "Individually handcrafted for your specific journey."
          }
        }
      ]
    }
  ]
}
{% endschema %}
