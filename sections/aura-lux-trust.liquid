{%- style -%}
  .aura-trust {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #F2F2F0;
  }

  .aura-trust__inner {
    max-width: 100rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .aura-trust__item {
    padding: 4rem 3rem;
    text-align: center;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 12px;
  }

  .aura-trust__icon {
    width: 2.4rem;
    height: 2.4rem;
    margin: 0 auto 2rem;
    opacity: 0.35;
  }

  .aura-trust__heading {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.8rem;
    font-weight: 500;
  }

  .aura-trust__text {
    font-size: 1.3rem;
    opacity: 0.5;
    line-height: 1.7;
    max-width: 26rem;
    margin: 0 auto;
  }

  @media screen and (max-width: 749px) {
    .aura-trust__inner {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .aura-trust__item {
      padding: 3rem 2rem;
    }
  }
{%- endstyle -%}

<section class="aura-trust">
  <div class="page-width">
    <div class="aura-trust__inner">
      {%- for block in section.blocks -%}
        <div class="aura-trust__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_svg != blank -%}
            <div class="aura-trust__icon">{{ block.settings.icon_svg }}</div>
          {%- else -%}
            <div class="aura-trust__icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
          {%- endif -%}

          <h3 class="aura-trust__heading">{{ block.settings.title | escape }}</h3>
          <p class="aura-trust__text">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Trust Bar",
  "max_blocks": 4,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Complimentary worldwide delivery on all orders."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "title": "Ethical Sourcing",
            "text": "Responsibly sourced materials, always."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Lifetime Warranty",
            "text": "Quality backed by a lifetime guarantee."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Precision Crafted",
            "text": "Individually crafted for perfection."
          }
        }
      ]
    }
  ]
}
{% endschema %}
