{%- style -%}
  .aura-story {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #111111;
    color: #F5F5F0;
    position: relative;
    overflow: hidden;
  }

  .aura-story::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197, 160, 89, 0.15), transparent);
  }

  .aura-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 6rem;
  }

  .aura-story__content {
    max-width: 50rem;
  }

  .aura-story__label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.5rem;
    font-size: 1rem;
    color: #C5A059;
    margin-bottom: 2.5rem;
    font-weight: 600;
  }

  .aura-story__heading {
    margin-bottom: 3.5rem;
    font-size: calc(var(--font-heading-scale) * 3.8rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: #F5F5F0;
  }

  .aura-story__text {
    font-size: 1.7rem;
    line-height: 1.9;
    color: rgba(245, 245, 240, 0.6);
    margin-bottom: 4.5rem;
    font-weight: 400;
  }

  .aura-story__cta.button {
    border-color: rgba(245, 245, 240, 0.2);
    color: #F5F5F0;
  }

  .aura-story__cta.button::after {
    background-color: #F5F5F0;
  }

  .aura-story__cta.button:hover {
    color: #111111;
  }

  .aura-story__image-wrap {
    position: relative;
  }

  .aura-story__image-frame {
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(197, 160, 89, 0.08);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .aura-story__image-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(13, 13, 13, 0.1), transparent 50%, rgba(13, 13, 13, 0.15));
    z-index: 1;
    pointer-events: none;
  }

  .aura-story__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    transition: transform 1.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .aura-story__image-wrap:hover .aura-story__image {
    transform: scale(1.03);
  }

  @media screen and (min-width: 990px) {
    .aura-story__grid {
      grid-template-columns: 5fr 6fr;
      gap: 8rem;
    }
    .aura-story__grid--reverse {
      grid-template-columns: 6fr 5fr;
    }
    .aura-story__grid--reverse .aura-story__content-wrap {
      order: 2;
    }
    .aura-story__grid--reverse .aura-story__image-wrap {
      order: 1;
    }
    .aura-story__heading {
      font-size: calc(var(--font-heading-scale) * 4.5rem);
    }
  }

  @media screen and (max-width: 749px) {
    .aura-story__image {
      aspect-ratio: 3 / 4;
    }
  }
{%- endstyle -%}

<section class="aura-story">
  <div class="page-width">
    <div class="aura-story__grid {% if section.settings.layout == 'text_first' %} aura-story__grid--reverse{% endif %}">

      <div class="aura-story__item aura-story__content-wrap">
        <div class="aura-story__content">
          {%- if section.settings.subheading != blank -%}
            <span class="aura-story__label">{{ section.settings.subheading | escape }}</span>
          {%- endif -%}

          <h2 class="aura-story__heading h1">{{ section.settings.heading | escape }}</h2>

          <div class="aura-story__text">{{ section.settings.text }}</div>

          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link }}" class="button aura-story__cta">
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="aura-story__item aura-story__image-wrap">
        <div class="aura-story__image-frame">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1500 | image_tag:
              class: 'aura-story__image',
              loading: 'lazy'
            }}
          {%- else -%}
            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-label",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for Silence, Crafted for You"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Aura Lux was born from a desire to reclaim luxury from the loud and the ostentatious. Our jewelry speaks in whispers, celebrating the quiet strength of minimalist design and ethical craftsmanship.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_first", "label": "Image First" },
        { "value": "text_first", "label": "Text First" }
      ],
      "default": "image_first"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Story"
    }
  ]
}
{% endschema %}
