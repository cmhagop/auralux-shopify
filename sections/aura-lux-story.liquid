{%- style -%}
  .aura-story {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
  }

  .aura-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 4rem;
  }

  .aura-story__content {
    max-width: 48rem;
  }

  .aura-story__label {
    display: block;
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.4;
    margin-bottom: 2rem;
  }

  .aura-story__heading {
    font-size: clamp(2.6rem, 3.5vw, 3.8rem);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 2.5rem;
  }

  .aura-story__text {
    font-size: 1.55rem;
    line-height: 1.8;
    opacity: 0.6;
    margin-bottom: 3.5rem;
  }

  .aura-story__image-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }

  .aura-story__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    transition: transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .aura-story__image-wrap:hover .aura-story__image {
    transform: scale(1.02);
  }

  @media screen and (min-width: 990px) {
    .aura-story__grid {
      grid-template-columns: 1fr 1fr;
      gap: 8rem;
    }
    .aura-story__grid--reverse {
      direction: rtl;
    }
    .aura-story__grid--reverse > * {
      direction: ltr;
    }
  }

  @media screen and (max-width: 749px) {
    .aura-story__image {
      aspect-ratio: 3 / 4;
      border-radius: 10px;
    }
  }
{%- endstyle -%}

<section class="aura-story">
  <div class="page-width">
    <div class="aura-story__grid {% if section.settings.layout == 'text_first' %} aura-story__grid--reverse{% endif %}">
      <div class="aura-story__item aura-story__content-wrap">
        <div class="aura-story__content">
          {%- if section.settings.subheading != blank -%}
            <span class="aura-story__label">{{ section.settings.subheading | escape }}</span>
          {%- endif -%}

          <h2 class="aura-story__heading">{{ section.settings.heading | escape }}</h2>

          <div class="aura-story__text">{{ section.settings.text }}</div>

          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link }}" class="button">
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="aura-story__item aura-story__image-wrap">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1500 | image_tag: class: 'aura-story__image', loading: 'lazy' }}
        {%- else -%}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-label",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Precision meets elegance"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every Aura Ring is a testament to what happens when meticulous engineering meets refined design. No compromises, no shortcuts — just quiet perfection.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_first", "label": "Image First" },
        { "value": "text_first", "label": "Text First" }
      ],
      "default": "image_first"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Story"
    }
  ]
}
{% endschema %}
