{%- style -%}
  .aura-lux-story-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
  }

  .aura-lux-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 8rem;
  }

  .aura-lux-story__item {
    position: relative;
    overflow: visible;
  }

  .aura-lux-story__content {
    max-width: 55rem;
  }

  .aura-lux-story__label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.5rem;
    font-size: 1.1rem;
    color: rgb(var(--color-accent));
    margin-bottom: 2.5rem;
    font-weight: 600;
  }

  .aura-lux-story__heading {
    margin-bottom: 3.5rem;
    font-size: calc(var(--font-heading-scale) * 4.2rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .aura-lux-story__text {
    font-size: 1.8rem;
    line-height: 1.9;
    opacity: 0.8;
    margin-bottom: 5rem;
    font-weight: 400;
  }

  .aura-lux-story__image-wrap {
    position: relative;
    padding: 2rem;
  }

  .aura-lux-story__image-wrap::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 105%;
    height: 105%;
    background: #F2F2F0;
    transform: translate(-50%, -50%);
    z-index: -1;
    border: 1px solid rgba(0,0,0,0.03);
  }

  .aura-lux-story__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    transition: transform 1.2s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .aura-lux-story__item:hover .aura-lux-story__image {
    transform: scale(1.02);
  }

  @media screen and (min-width: 990px) {
    .aura-lux-story__grid {
      grid-template-columns: 4fr 6fr;
    }
    .aura-lux-story__grid--reverse {
      grid-template-columns: 6fr 4fr;
    }
    .aura-lux-story__grid--reverse .aura-lux-story__content-wrap {
      order: 2;
    }
    .aura-lux-story__grid--reverse .aura-lux-story__image-wrap {
      order: 1;
    }
    .aura-lux-story__content {
      margin-left: auto;
    }
    .aura-lux-story__grid--reverse .aura-lux-story__content {
      margin-left: 0;
      margin-right: auto;
    }
  }

  @media screen and (max-width: 749px) {
    .aura-lux-story__grid {
      gap: 6rem;
    }
    .aura-lux-story__image-wrap {
      padding: 0;
    }
    .aura-lux-story__image-wrap::before {
      display: none;
    }
  }
{%- endstyle -%}

<section class="aura-lux-story-{{ section.id }} isolation-blend">
  <div class="page-width">
    <div class="aura-lux-story__grid {% if section.settings.layout == 'text_first' %} aura-lux-story__grid--reverse{% endif %}">
      
      <div class="aura-lux-story__item aura-lux-story__content-wrap">
        <div class="aura-lux-story__content">
          {%- if section.settings.subheading != blank -%}
            <span class="aura-lux-story__label">{{ section.settings.subheading | escape }}</span>
          {%- endif -%}
          
          <h2 class="aura-lux-story__heading h1">{{ section.settings.heading | escape }}</h2>
          
          <div class="aura-lux-story__text">{{ section.settings.text }}</div>
          
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link }}" class="button">
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="aura-lux-story__item aura-lux-story__image-wrap">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1500 | image_tag: 
            class: 'aura-lux-story__image',
            loading: 'lazy'
          }}
        {%- else -%}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aura Lux Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-label",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for Silence, Crafted for You"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Aura Lux was born from a desire to reclaim luxury from the loud and the ostentatious. Our jewelry speaks in whispers, celebrating the quiet strength of minimalist design and ethical craftsmanship.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_first", "label": "Image First" },
        { "value": "text_first", "label": "Text First" }
      ],
      "default": "image_first"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Aura Lux Story"
    }
  ]
}
{% endschema %}
